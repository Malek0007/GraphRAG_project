  "evidence": [
    {
      "claim": "ScarCruft used a multi-stage binary infection chain with UAC bypass to elevate privileges.",
      "evidence_text": "One of the most notable functions of the initial dropper is to bypass Windows UAC ... using CVE-2018-8120 or UACME."
    },
    {
      "claim": "The downloader used steganography to fetch the next payload.",
      "evidence_text": "The downloader uses steganography. The downloaded payload is an image file, but it contains an appended malicious payload to be decrypted."
    },
    {
      "claim": "ROKRAT used cloud services for command retrieval and exfiltration.",
      "evidence_text": "Commands are downloaded from the /script path ... results are uploaded to the /scriptout path ... forwarding collected data to Box, Dropbox, Pcloud and Yandex."
    },
    {
      "claim": "ScarCruft introduced a Bluetooth device harvester.",
      "evidence_text": "This malware uses Windows Bluetooth APIs to find information on connected Bluetooth devices and saves device information."
    }
  ]
