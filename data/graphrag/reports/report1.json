  "evidence": [
    {
      "claim": "Raspberry Robin spreads via infected USB using .lnk files.",
      "evidence_text": "The campaign and malware ... seemingly spreads to systems with worm-like capabilities (due to the use of .lnk files) via an infected USB."
    },
    {
      "claim": "The malware downloads an MSI payload through legitimate Windows executables.",
      "evidence_text": "The LNK file contains a command line that runs a legitimate executable to download a Windows Installer (MSI) package ... usually msiexec.exe, but wmic.exe in other samples."
    },
    {
      "claim": "The malware performs UAC bypass through a variation of ucmDccwCOMMethod using elevated COM interfaces and registry calibration settings.",
      "evidence_text": "It executes the dropped copy as Administrator using a UAC bypass technique ... variation of ucmDccwCOMMethod ... creates an elevated COM object for CMLuaUtil ... sets DisplayCalibrator ... calls LaunchDccw."
    },
    {
      "claim": "The real payload connects to Tor through an injected client process.",
      "evidence_text": "The real payload attempts to connect to the hard-coded Tor addresses ... randomly selects a name among dllhost.exe, regsvr32.exe, rundll32.exe ... injects the code of the Tor client."
    }
  ]
